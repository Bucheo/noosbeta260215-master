<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  BoardMapper.xml
  ─────────────────────────────────────────────────────────────────────────────
  게시판 MyBatis SQL 매핑 파일
  네임스페이스: com.noos.backend.auth.mapper.BoardMapper

  연결 테이블:
    board_posts    - 게시글 저장
    board_comments - 댓글 저장
  ─────────────────────────────────────────────────────────────────────────────
-->
<mapper namespace="com.noos.backend.auth.mapper.BoardMapper">

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!-- ResultMap: board_posts 컬럼 ↔ BoardPost 필드 매핑                   -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <resultMap id="postResultMap" type="com.noos.backend.auth.dto.BoardPost">
        <id     property="id"           column="id"            />
        <result property="category"     column="category"      />
        <result property="title"        column="title"         />
        <result property="content"      column="content"       />
        <result property="author"       column="author"        />
        <result property="authorId"     column="author_id"     />
        <result property="views"        column="views"         />
        <result property="likes"        column="likes"         />
        <result property="commentCount" column="comment_count" />
        <result property="pinned"       column="pinned"        />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!-- ResultMap: board_comments 컬럼 ↔ BoardComment 필드 매핑             -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <resultMap id="commentResultMap" type="com.noos.backend.auth.dto.BoardComment">
        <id     property="id"        column="id"         />
        <result property="postId"    column="post_id"    />
        <result property="authorId"  column="author_id"  />
        <result property="author"    column="author"     />
        <result property="content"   column="content"    />
        <result property="likes"     column="likes"      />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  게시글 목록 조회                                                    -->
    <!--  - 카테고리 필터, 검색어(제목/작성자), 정렬, 페이징 지원              -->
    <!--  - 고정(pinned) 게시글이 항상 먼저 오도록 ORDER BY pinned DESC 선두  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <select id="findPosts" resultMap="postResultMap">
        SELECT
            id, category, title, content, author, author_id,
            views, likes, comment_count, pinned, created_at, updated_at
        FROM board_posts
        <where>
            <!-- 카테고리 필터: null이면 조건 생략 → 전체 조회 -->
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <!-- 검색어: 제목 또는 작성자 이름에서 LIKE 검색 -->
            <if test="searchQuery != null and searchQuery != ''">
                AND (
                    title  LIKE CONCAT('%', #{searchQuery}, '%')
                    OR author LIKE CONCAT('%', #{searchQuery}, '%')
                )
            </if>
        </where>
        ORDER BY
            pinned DESC,  <!-- 고정 게시글 항상 상단 -->
            <choose>
                <when test="sortBy == 'views'">    views         DESC</when>
                <when test="sortBy == 'likes'">    likes         DESC</when>
                <when test="sortBy == 'comments'"> comment_count DESC</when>
                <otherwise>                        created_at    DESC</otherwise> <!-- 기본: 최신순 -->
            </choose>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 게시글 총 개수 (페이지네이션 계산용) -->
    <select id="countPosts" resultType="int">
        SELECT COUNT(*)
        FROM board_posts
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="searchQuery != null and searchQuery != ''">
                AND (
                    title  LIKE CONCAT('%', #{searchQuery}, '%')
                    OR author LIKE CONCAT('%', #{searchQuery}, '%')
                )
            </if>
        </where>
    </select>

    <!-- 게시글 단건 조회 -->
    <select id="findPostById" resultMap="postResultMap">
        SELECT
            id, category, title, content, author, author_id,
            views, likes, comment_count, pinned, created_at, updated_at
        FROM board_posts
        WHERE id = #{id}
    </select>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  게시글 등록                                                         -->
    <!--  useGeneratedKeys: INSERT 후 auto-increment PK를 dto.id에 자동 주입  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <insert id="insertPost" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board_posts
            (category, title, content, author, author_id, pinned, views, likes, comment_count, created_at)
        VALUES
            (#{category}, #{title}, #{content}, #{author}, #{authorId}, #{pinned}, 0, 0, 0, #{createdAt})
    </insert>

    <!-- 게시글 수정 (제목·본문·카테고리·고정 여부) -->
    <update id="updatePost">
        UPDATE board_posts
        SET
            category   = #{category},
            title      = #{title},
            content    = #{content},
            pinned     = #{pinned},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!-- 게시글 삭제 (관련 댓글은 ON DELETE CASCADE 또는 별도 삭제 처리) -->
    <delete id="deletePost">
        DELETE FROM board_posts WHERE id = #{id}
    </delete>

    <!-- 조회수 1 증가 -->
    <update id="incrementViews">
        UPDATE board_posts SET views = views + 1 WHERE id = #{id}
    </update>

    <!-- 좋아요 1 증가 -->
    <update id="incrementLikes">
        UPDATE board_posts SET likes = likes + 1 WHERE id = #{id}
    </update>

    <!-- 좋아요 1 감소 (최솟값 0 보장) -->
    <update id="decrementLikes">
        UPDATE board_posts SET likes = GREATEST(0, likes - 1) WHERE id = #{id}
    </update>

    <!-- 유저가 특정 게시글에 좋아요를 눌렀는지 확인 (1=눌렀음, 0=안 눌렀음) -->
    <select id="checkUserLiked" resultType="int">
        SELECT COUNT(*) FROM board_post_likes
        WHERE user_id = #{userId} AND post_id = #{postId}
    </select>

    <!-- 좋아요 기록 INSERT (첫 클릭 시) -->
    <insert id="insertUserLike">
        INSERT IGNORE INTO board_post_likes (user_id, post_id)
        VALUES (#{userId}, #{postId})
    </insert>

    <!-- 좋아요 기록 DELETE (재클릭 시 취소) -->
    <delete id="deleteUserLike">
        DELETE FROM board_post_likes
        WHERE user_id = #{userId} AND post_id = #{postId}
    </delete>

    <!-- 댓글 수 1 증가 -->
    <update id="incrementCommentCount">
        UPDATE board_posts SET comment_count = comment_count + 1 WHERE id = #{id}
    </update>

    <!-- 댓글 수 1 감소 (최솟값 0 보장) -->
    <update id="decrementCommentCount">
        UPDATE board_posts SET comment_count = GREATEST(0, comment_count - 1) WHERE id = #{id}
    </update>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  댓글 쿼리                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- 특정 게시글의 댓글 목록 (등록 순 오름차순) -->
    <select id="findCommentsByPostId" resultMap="commentResultMap">
        SELECT id, post_id, author_id, author, content, likes, created_at, updated_at
        FROM board_comments
        WHERE post_id = #{postId}
        ORDER BY created_at ASC
    </select>

    <!-- 댓글 단건 조회 (삭제 시 작성자 확인용) -->
    <select id="findCommentById" resultMap="commentResultMap">
        SELECT id, post_id, author_id, author, content, likes, created_at, updated_at
        FROM board_comments
        WHERE id = #{id}
    </select>

    <!-- 댓글 등록 -->
    <insert id="insertComment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board_comments
            (post_id, author_id, author, content, likes, created_at)
        VALUES
            (#{postId}, #{authorId}, #{author}, #{content}, 0, #{createdAt})
    </insert>

    <!-- 댓글 삭제 -->
    <delete id="deleteComment">
        DELETE FROM board_comments WHERE id = #{id}
    </delete>

    <!-- 댓글 좋아요 1 증가 -->
    <update id="incrementCommentLikes">
        UPDATE board_comments SET likes = likes + 1 WHERE id = #{id}
    </update>

    <!-- 댓글 좋아요 1 감소 (최솟값 0 보장) -->
    <update id="decrementCommentLikes">
        UPDATE board_comments SET likes = GREATEST(0, likes - 1) WHERE id = #{id}
    </update>

    <!-- 유저가 댓글에 좋아요를 눌렀는지 확인 (1=눌렀음, 0=안 눌렀음) -->
    <select id="checkUserCommentLiked" resultType="int">
        SELECT COUNT(*) FROM board_comment_likes
        WHERE user_id = #{userId} AND comment_id = #{commentId}
    </select>

    <!-- 댓글 좋아요 기록 INSERT (첫 클릭) -->
    <insert id="insertUserCommentLike">
        INSERT IGNORE INTO board_comment_likes (user_id, comment_id)
        VALUES (#{userId}, #{commentId})
    </insert>

    <!-- 댓글 좋아요 기록 DELETE (재클릭 시 취소) -->
    <delete id="deleteUserCommentLike">
        DELETE FROM board_comment_likes
        WHERE user_id = #{userId} AND comment_id = #{commentId}
    </delete>

</mapper>