<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.noos.backend.auth.mapper.AdminMapper">

    <select id="findAllUsers" resultType="com.noos.backend.auth.dto.User">
        SELECT 
            user_id AS userId,
            login_id AS loginId,
            display_name AS displayName,
            role,
            created_at AS createdAt,
            provider
            FROM users
            ORDER BY created_at DESC
    </select>

</mapper>